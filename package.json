{
  "name": "dexter-ts",
  "version": "2026.5.1",
  "description": "Dexter - AI agent for deep financial research.",
  "type": "module",
  "main": "src/index.tsx",
  "bin": {
    "dexter-ts": "./src/index.tsx"
  },
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun --watch run src/index.tsx",
    "gateway": "tsx src/gateway/index.ts run",
    "gateway:login": "tsx src/gateway/index.ts login",
    "webui:dev": "next dev --hostname 127.0.0.1 --port 5173",
    "webui:build": "next build",
    "webui:preview": "next start --hostname 127.0.0.1 --port 4173",
    "webui:start": "bun run src/webui/server/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.25",
    "@langchain/core": "^1.1.36",
    "@langchain/exa": "^1.0.1",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.3.1",
    "@langchain/tavily": "^1.2.0",
    "@mariozechner/pi-tui": "^0.52.12",
    "@mozilla/readability": "^0.6.0",
    "@radix-ui/react-slot": "^1.2.3",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "croner": "^9.1.0",
    "diff": "^8.0.4",
    "dotenv": "^17.3.1",
    "exa-js": "^2.10.1",
    "gray-matter": "^4.0.3",
    "langsmith": "^0.4.12",
    "linkedom": "^0.18.12",
    "lucide-react": "^0.536.0",
    "next": "^15.3.3",
    "playwright": "^1.58.2",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/react": "^19.1.15",
    "@types/react-dom": "^19.1.9",
    "@types/node": "^22.15.32",
    "@types/jest": "^29.5.14",
    "@types/qrcode-terminal": "^0.12.2",
    "babel-jest": "^30.3.0",
    "jest": "^29.7.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
